{
  "manifest_version": 3,
  "name": "Ephemeral Cypher Companion",
  "version": "1.0.0",
  "description": "Use the page you are viewing as an on-device Ephemeral Cypher key fingerprint.",
  "permissions": ["activeTab", "scripting"],
  "action": {
    "default_title": "Use this page with Ephemeral Cypher",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
